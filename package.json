{
  "name": "@framers/agentos-skills-registry",
  "version": "0.19.0",
  "files": [
    "dist",
    "README.md"
  ],
  "description": "Catalog SDK for AgentOS skills — query helpers, lazy loaders, and factory functions for curated SKILL.md prompt modules. Companion to the @framers/agentos TypeScript AI agent runtime.",
  "homepage": "https://agentos.sh",
  "bugs": {
    "url": "https://github.com/framerslab/agentos-skills-registry/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./catalog": {
      "import": "./dist/catalog.js",
      "default": "./dist/catalog.js",
      "types": "./dist/catalog.d.ts"
    },
    "./workspace-discovery": {
      "import": "./dist/workspace-discovery.js",
      "default": "./dist/workspace-discovery.js",
      "types": "./dist/workspace-discovery.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "test -d dist || npm run build",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framerslab/agentos-skills-registry.git"
  },
  "keywords": [
    "agentos",
    "framers-agentos",
    "agentos-skills",
    "agentos-skills-registry",
    "skills",
    "skills-registry",
    "registry",
    "catalog-sdk",
    "lazy-loading",
    "ai-agent",
    "ai-agents",
    "ai-agent-skills",
    "agent-framework",
    "prompt-modules",
    "prompts",
    "framers",
    "frame-dev"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@framers/agentos-skills": "^0.10.1",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "@framers/agentos": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "@framers/agentos": {
      "optional": true
    }
  },
  "devDependencies": {
    "@framers/agentos": "^0.9.134",
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "vitest": "^1.0.0"
  }
}
